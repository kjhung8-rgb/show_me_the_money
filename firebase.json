{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git",
      ".git/**",
      ".gitignore",
      ".firebase",
      ".firebase/**",
      "README.md",
      "AGENTS.md",
      ".env",
      ".env.*",
      "*.log",
      "firebase-debug.log",
      "node_modules",
      "node_modules/**",
      ".DS_Store"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}